// Jenkinsfile MẪU — Build Lambda Layer `videopress-common`.
// Trigger: PR đụng path `layer/**` hoặc merge main đụng path đó.
// Đặt tại `videopress-backend/Jenkinsfile.layer-build`.

@Library('videopress-cicd@v1.2.0') _

pipeline {
  agent any

  options {
    timeout(time: 20, unit: 'MINUTES')
    timestamps()
  }

  environment {
    PYTHON_VERSION  = '3.11'
    LAYER_BUCKET    = 'videopress-artifacts-non-prod'
    LAYER_NAME      = 'videopress-common'
  }

  stages {
    stage('Checkout') { steps { checkout scm } }

    stage('Build layer zip') {
      steps {
        sh '''
          set -e
          mkdir -p build/layer/python
          pip install -r layer/requirements-layer.txt \
            --target build/layer/python \
            --platform manylinux2014_x86_64 \
            --only-binary=:all:
          cd build/layer && zip -r ../layer.zip python
        '''
      }
    }

    stage('Publish layer version') {
      steps {
        script {
          def version = sh(
            script: """
              aws lambda publish-layer-version \\
                --layer-name ${env.LAYER_NAME} \\
                --zip-file fileb://build/layer.zip \\
                --compatible-runtimes python${env.PYTHON_VERSION} \\
                --query Version --output text
            """,
            returnStdout: true
          ).trim()
          echo "📦 Published layer ${env.LAYER_NAME} version=${version}"
        }
      }
    }
  }
}
